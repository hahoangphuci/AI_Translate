# Copy to backend/.env and fill values for local development
# Do NOT commit real secrets to the repository.

# App keys
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI used for OAuth callbacks (use 127.0.0.1 for local dev)
GOOGLE_REDIRECT_URI=http://127.0.0.1:5055/api/auth/google/callback
# Public URL for frontend (set automatically by scripts/ngrok-start.ps1)
FRONTEND_URL=http://127.0.0.1:5055

# ngrok (https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=

# Database: default uses MySQL (XAMPP). If MySQL is down, app auto-falls back to SQLite.
# Example MySQL: mysql+pymysql://root:password@127.0.0.1:3306/ai_translation
# Example SQLite (manual): sqlite:///D:/path/to/api_base/instance/translation.db
DATABASE_URL=mysql+pymysql://root:@localhost:3306/ai_translation
# DB_FORCE_SQLITE=1              # always use SQLite (skip MySQL)
# DB_DISABLE_SQLITE_FALLBACK=1   # fail if MySQL unavailable (no auto fallback)
# SQLITE_DATABASE_URL=sqlite:///D:/path/to/custom.db

# Payment (sepay)
SEPAY_API_KEY=
# Optional: webhook auth key (defaults to SEPAY_API_KEY)
SEPAY_WEBHOOK_API_KEY=
# Kept for backward-compatibility with older setups (not used by current code)
SEPAY_SECRET=
SEPAY_BASE_URL=https://my.sepay.vn
SEPAY_HISTORY_ENDPOINT=/userapi/transactions/list

# Payment polling + transfer content
NAME_WEB=AITRANS
PAYMENT_TRANSFER_KEYWORD=NAPTOKEN
PAYMENT_XOR_KEY=0x5EAFB
PAYMENT_EXPIRE_MINUTES=60
PAYMENT_POLL_TX_LIMIT=20

# Optional QR info (VietQR)
PAYMENT_BANK_CODE=MB
PAYMENT_BANK_ACCOUNT=
PAYMENT_BANK_ACCOUNT_NAME=

# Optional: use SePay QR image generator instead of img.vietqr.io
# Docs: https://qr.sepay.vn/
# Example (fill acc/bank accordingly):
# SEPAY_QR_TEMPLATE_URL=https://qr.sepay.vn/img?acc={account_number}&bank={bank_code}&amount={amount}&des={content}&template=compact
SEPAY_QR_TEMPLATE_URL=

# Email SMTP (OTP đăng ký / quên mật khẩu)
ADMIN_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true


# AI provider keys
OPENAI_API_KEY=
DEEPL_API_KEY=
# Để trống GEMINI_API_KEY nếu muốn Gemini dịch qua OpenRouter
GEMINI_API_KEY=
GEMINI_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=
AI_PROVIDER=openrouter
AI_MODEL=google/gemini-2.5-flash
TRANSLATION_PROVIDER_DEFAULT=gemini
# Keep document translation quality high: if Gemini/DeepL fails, fail the job instead of silently falling back to Google.
DOCUMENT_TRANSLATION_ALLOW_GOOGLE_FALLBACK=0

# OCR (Image -> Text)
# Windows example: TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=
# Default OCR languages for Tesseract (use '+' to combine)
OCR_LANGS_DEFAULT=eng+vie

# PDF translation uses the DOCX pipeline (PDF -> DOCX -> translate -> PDF)
# Legacy PDF_TRANSLATION_PIPELINE is ignored; only docx pipeline is supported.

# PDF -> DOCX converter: pdf2docx | word | adobe
PDF_DOCX_CONVERTER=pdf2docx
# Preserve end-line hyphen characters from source PDF unless explicitly enabled
PDF2DOCX_DELETE_HYPHEN=0

# DOCX -> PDF engine: auto | docx2pdf | libreoffice
PDF_DOCX_EXPORT_ENGINE=auto

# Keep intermediate DOCX files for debugging
PDF_DOCX_KEEP_INTERMEDIATE=0

# Layout recovery: copy paragraph properties from pre-translation DOCX (safe mode)
PDF_DOCX_MIRROR_LAYOUT=1
PDF_DOCX_LAYOUT_SYNC=1
PDF_DOCX_PDF_FORMAT_SYNC=0
PDF_DOCX_PDF_ALIGN_SYNC=0
PDF_DOCX_TABLE_SYNC=1
PDF_DOCX_HEADER_FOOTER_SYNC=1
PDF_DOCX_MERGE_FRAGMENTS=0
PDF_DOCX_FIX_ANOMALIES=0
PDF_DOCX_STRIP_NOISE=1
PDF_DOCX_NORMALIZE_ALIGN=1
PDF_DOCX_NORMALIZE_INDENTS=1
PDF_DOCX_FORCE_BODY_JUSTIFY=0
PDF_DOCX_SANITIZE_MERGE_FRAGMENTS=0
PDF_DOCX_SANITIZE_REPLACE_NBSP=1
PDF_DOCX_SANITIZE_REPLACE_TABS=0
PDF_DOCX_SANITIZE_STRIP_SOFT_HYPHEN=0
PDF_DOCX_NORMALIZE_SUBSET_FONTS=1
PDF_DOCX_FIX_SYMBOL_FONT_RUNS=1
PDF_DOCX_TEXT_FONT_FALLBACK=Times New Roman
# Map pdf2docx/script/PS fonts to stable Windows fonts before PDF export
PDF_DOCX_SANITIZE_FONTS=1
PDF_DOCX_CANONICALIZE_UNKNOWN_FONTS=1
PDF_DOCX_PDF_GEOMETRY_PROFILE=1
PDF_DOCX_REGIONAL_LAYOUT=1
PDF_DOCX_REGIONAL_MODE=auto
# Keep source DOCX/PDF layout: force | auto | off
PDF_DOCX_PRESERVE_LAYOUT_MODE=force
# Merge wrapped line-breaks only for prose-like from-PDF paragraphs (off to avoid accidental line fusion)
PDF_DOCX_MERGE_SOFT_BREAKS=0
PDF_DOCX_ACADEMIC_LAYOUT=0
PDF_DOCX_FONT_FIT=0
PDF_DOCX_SANITIZE_FORCE_LEFT=0

# Strict mode: fail if scan OCR cannot create searchable PDF
PDF_SCAN_OCR_STRICT=0

# PDF cleanup controls (used by scan OCR + cleaning stage)
PDF_CLEAN_NORMALIZE_ROTATION=1
PDF_CLEAN_AUTOROTATE=1
PDF_CLEAN_DESKEW=1
PDF_CLEAN_ENHANCE=1
PDF_CLEAN_RENDER_DPI=250

# Translation guard for DOCX (skip URL/DOI/reference/formula/code)
DOCX_TRANSLATION_GUARD=1

# Account deletion grace period (days) and OTP / scheduler
ACCOUNT_DELETE_GRACE_DAYS=30
ACCOUNT_DELETE_OTP_TTL_MIN=5
ACCOUNT_RESTORE_OTP_TTL_MIN=5
ACCOUNT_DELETE_OTP_LOCK_MIN=15
ACCOUNT_DELETE_SCHEDULER_SEC=3600

# Optional post-fixes (off by default to avoid document-specific rewrites)
DOCX_TARGETED_FIXES=0
DOCX_DOMAIN_FIXUPS=0

# Layout recovery for long table cells
DOCX_TABLE_SHRINK=0
DOCX_TABLE_SHRINK_LEN=140
DOCX_TABLE_SHRINK_MIN_PT=8
